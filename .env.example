# ── Docker 部署（默认）────────────────────────────────
# 复制为 .env 后填写外置 MySQL / Redis 地址；docker compose up 只启动应用三端，不自带 mysql/redis。
# cp .env.example .env

# ── MySQL（外置）──────────────────────────────────────
MYSQL_DATABASE=agent_platform
MYSQL_USER=iot5
MYSQL_PASSWORD=jsglUiMCqTEco8Ja
DATABASE_URL=mysql://iot5:jsglUiMCqTEco8Ja@192.168.109.211:3306/agent_platform

# ── Redis（外置）──────────────────────────────────────
REDIS_HOST=10.30.20.220
REDIS_PORT=7002
REDIS_PASSWORD=gAlbNoAaWYEhdEYJ

# 生产/内网 Jenkins：已有库数据时保持 false，避免每次启动重跑 seed
SEED_ON_STARTUP=false

# ── shellder-agent-server ──────────────────────────────
AGENT_SERVER_PORT=3001
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# 连接器凭证加密密钥（阶段 06）：用于 AES-256-GCM 加密连接器凭证，生产必须配置高强度随机串
CONNECTOR_SECRET_KEY=change-me-to-a-long-random-connector-secret-key

# ── shellder-job-worker ────────────────────────────────
JOB_WORKER_PORT=3002

# ── shellder-web-console ───────────────────────────────
WEB_CONSOLE_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ── 本地可选：Compose 内置 mysql/redis（profile bundled-infra）──
# 仅在使用 docker-compose.bundled-infra.yml 时取消注释并改为容器内主机名：
# MYSQL_ROOT_PASSWORD=changeme_root
# MYSQL_USER=agent
# MYSQL_PASSWORD=changeme_agent
# DATABASE_URL=mysql://agent:changeme_agent@mysql:3306/agent_platform
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# SEED_ON_STARTUP=true

# ── 监控（可选，docker compose --profile monitoring up）─
GRAFANA_ADMIN_PASSWORD=changeme_grafana
