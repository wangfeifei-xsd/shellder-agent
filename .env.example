# ── MySQL ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=agent_platform
MYSQL_USER=agent
MYSQL_PASSWORD=changeme_agent
DATABASE_URL=mysql://agent:changeme_agent@localhost:3306/agent_platform

# ── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── shellder-agent-server ──────────────────────────────
AGENT_SERVER_PORT=3001
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# 连接器凭证加密密钥（阶段 06）：用于 AES-256-GCM 加密连接器凭证，生产必须配置高强度随机串
CONNECTOR_SECRET_KEY=change-me-to-a-long-random-connector-secret-key

# ── shellder-job-worker ────────────────────────────────
JOB_WORKER_PORT=3002
# worker → server 内网调用（方案 B，与 server 保持一致）
AGENT_SERVER_INTERNAL_URL=http://127.0.0.1:3001
WORKER_INTERNAL_TOKEN=change-me-worker-internal-token

# ── shellder-web-console ───────────────────────────────
WEB_CONSOLE_PORT=3000
# 开发环境留空即可走 Vite 代理；生产 Docker 由 nginx 反代 /api
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:3001

# ── pathy-knowledge-server（知识库代理，V1 必选）──
PATHY_KNOWLEDGE_SERVER_BASE_URL=http://127.0.0.1:8765
PATHY_KNOWLEDGE_SERVER_TIMEOUT_MS=30000

# job-worker 异步通知（默认 Mock 日志，不发起真实 HTTP）
NOTIFICATION_SEND_MOCK=true

# ── 监控（可选，docker compose --profile monitoring up）─
GRAFANA_ADMIN_PASSWORD=changeme_grafana
