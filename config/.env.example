# 本地 npm 开发环境变量模板（复制为 config/.env，可修改，不提交）
# 账号与 docker-compose.bundled-infra.yml 默认一致（agent / changeme_agent）

SHELLDER_PROFILE=default

DATABASE_URL=mysql://root:Root%401345@localhost:3306/agent_platform
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change-me-dev-secret
JWT_EXPIRES_IN=7d
CONNECTOR_SECRET_KEY=change-me-to-a-long-random-connector-secret-key
WORKER_INTERNAL_TOKEN=
