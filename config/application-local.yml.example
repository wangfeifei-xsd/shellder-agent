# 复制为 application-local.yml，并在 config/.env 设置 SHELLDER_PROFILE=local

infrastructure:
  database:
    url: ${DATABASE_URL:mysql://root:Root%401345@localhost:3306/agent_platform}
  redis:
    host: localhost
    port: 6379
    password: ''

services:
  web-console:
    api-base-url: http://localhost:3001
    api-proxy-target: http://localhost:3001
    default-origin: http://localhost:3000

auth:
  bootstrap:
    enabled: true
    admin-username: admin
    admin-password: admin123

app:
  notification:
    send-mock: true
