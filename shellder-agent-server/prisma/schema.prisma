// shellder-agent — Prisma 基线
// 业务表从阶段 02（tenant）起按模块递增，见 project-sql/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────
// 阶段 02 — 租户管理（实施规格 §1.3）
// Agent 平台自行维护租户主数据，非上层同步。
// ───────────────────────────────────────────────────────────

enum TenantStatus {
  enabled
  disabled
}

model Tenant {
  id               String       @id @default(uuid()) @db.Char(36)
  code             String       @unique @db.VarChar(64)
  name             String       @db.VarChar(128)
  status           TenantStatus @default(enabled)
  externalTenantId String?      @map("external_tenant_id") @db.VarChar(128)
  // config：开通能力(capabilities)、默认限额(limits)、隔离策略(isolation) 等，详见模块 README
  config           Json?
  adminUserId      String?      @map("admin_user_id") @db.Char(36)
  remark           String?      @db.VarChar(512)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  userTenants        UserTenant[]
  toolCallAudits     ToolCallAudit[]
  userActionAudits   UserActionAudit[]
  externalCallAudits ExternalCallAudit[]
  rules              Rule[]
  ruleHits           RuleHit[]
  connectors         Connector[]
  tools              Tool[]
  sessions           Session[]
  tasks              Task[]
  capabilities       Capability[]
  routingRules       RoutingRule[]
  skills             Skill[]
  skillExecutionLogs SkillExecutionLog[]
  knowledgeBases     KnowledgeBase[]
  kbDataSources      KbDataSource[]
  kbDocuments        KbDocument[]
  kbChunks           KbChunk[]
  kbEmbeddingTasks       KbEmbeddingTask[]
  kbLayerProcessingJobs  KbLayerProcessingJob[]
  approvals              Approval[]
  openApiCallLogs    OpenApiCallLog[]
  copilotConfigs     CopilotConfig[]
  promptTemplates    PromptTemplate[]
  promptBindings     PromptBinding[]

  @@index([status])
  @@index([externalTenantId])
  @@map("tenant")
}

// ───────────────────────────────────────────────────────────
// 阶段 03 — 用户与权限（功能清单 §1.10 / 实施规格 §1.5）
// 平台独立账号体系 + JWT + RBAC；用户绑定 Agent 库租户（多租户）。
// ───────────────────────────────────────────────────────────

enum UserStatus {
  enabled
  disabled
}

model User {
  id           String     @id @default(uuid()) @db.Char(36)
  username     String     @unique @db.VarChar(64)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  displayName  String?    @map("display_name") @db.VarChar(128)
  email        String?    @db.VarChar(128)
  status       UserStatus @default(enabled)
  isSystem     Boolean    @default(false) @map("is_system")
  remark       String?    @db.VarChar(512)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  roles   UserRole[]
  tenants UserTenant[]

  @@index([status])
  @@map("user")
}

model Role {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(128)
  description String?  @db.VarChar(512)
  // menus：菜单权限 key 列表（string[]）
  menus       Json?
  // modules：模块权限 key 列表（string[]）
  modules     Json?
  // toolScopes：可访问 Tool 权限范围 key 列表（string[]）
  toolScopes  Json?    @map("tool_scopes")
  // policy：能力级访问权限与高风险审批权限，结构见模块 README
  policy      Json?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users UserRole[]

  @@map("role")
}

model UserRole {
  userId String @map("user_id") @db.Char(36)
  roleId String @map("role_id") @db.Char(36)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

model UserTenant {
  userId   String @map("user_id") @db.Char(36)
  tenantId String @map("tenant_id") @db.Char(36)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@id([userId, tenantId])
  @@index([tenantId])
  @@map("user_tenant")
}

// ───────────────────────────────────────────────────────────
// 阶段 04 — 审计模块与审计中心（功能清单 §1.9 / 架构 §4.2 Audit）
// 三类采集通道：工具调用 / 用户操作 / 外部接口；
// 风险动作审计为聚合只读视图，不单独建表（执行计划 §3.4 / §5.2）。
// tenant_id 归属 tenant.id（实施规格 §1.4）；审计为保留性数据，
// 外键 onDelete: Restrict，且租户在平台内只禁用不删除。
// ───────────────────────────────────────────────────────────

enum AuditStatus {
  success
  failed
  pending
}

/// 工具调用审计：Tool 执行链路采集（07 起写入真实数据）
model ToolCallAudit {
  id             String      @id @default(uuid()) @db.Char(36)
  tenantId       String?     @map("tenant_id") @db.Char(36)
  toolId         String?     @map("tool_id") @db.Char(36)
  toolName       String      @map("tool_name") @db.VarChar(128)
  callerUserId   String?     @map("caller_user_id") @db.VarChar(256)
  callerName     String?     @map("caller_name") @db.VarChar(128)
  sessionId      String?     @map("session_id") @db.Char(36)
  taskId         String?     @map("task_id") @db.Char(36)
  // 入参摘要（脱敏后的文本，非完整原始入参）
  requestSummary String?     @map("request_summary") @db.Text
  status         AuditStatus @default(pending)
  errorMessage   String?     @map("error_message") @db.VarChar(1024)
  durationMs     Int?        @map("duration_ms")
  // 高风险标记：供风险动作审计聚合（05 策略 / 07 工具 / 14 审批 可置位）
  highRisk       Boolean     @default(false) @map("high_risk")
  createdAt      DateTime    @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([toolName])
  @@index([callerUserId])
  @@index([status])
  @@index([highRisk])
  @@index([createdAt])
  @@map("tool_call_audit")
}

/// 用户操作审计：后台配置 / 审批 / 权限变更等写操作（拦截器自动采集）
model UserActionAudit {
  id             String      @id @default(uuid()) @db.Char(36)
  tenantId       String?     @map("tenant_id") @db.Char(36)
  operatorUserId String?     @map("operator_user_id") @db.Char(36)
  operatorName   String?     @map("operator_name") @db.VarChar(128)
  // 操作标识，如 user.update / role.create / tenant.updateStatus
  action         String      @db.VarChar(128)
  module         String?     @db.VarChar(64)
  targetType     String?     @map("target_type") @db.VarChar(64)
  targetId       String?     @map("target_id") @db.VarChar(64)
  summary        String?     @db.VarChar(512)
  // 操作前后差异摘要 { before?, after?, params?, body? }
  diff           Json?
  status         AuditStatus @default(success)
  ip             String?     @db.VarChar(64)
  requestId      String?     @map("request_id") @db.VarChar(64)
  createdAt      DateTime    @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([operatorUserId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@map("user_action_audit")
}

/// 外部接口审计：调用外部系统的目标 / 状态 / 耗时 / 失败原因（06、13 起写入）
model ExternalCallAudit {
  id             String      @id @default(uuid()) @db.Char(36)
  tenantId       String?     @map("tenant_id") @db.Char(36)
  connectorId    String?     @map("connector_id") @db.Char(36)
  target         String      @db.VarChar(255)
  method         String?     @db.VarChar(16)
  callerUserId   String?     @map("caller_user_id") @db.VarChar(256)
  sessionId      String?     @map("session_id") @db.Char(36)
  taskId         String?     @map("task_id") @db.Char(36)
  requestSummary String?     @map("request_summary") @db.Text
  status         AuditStatus @default(success)
  statusCode     Int?        @map("status_code")
  durationMs     Int?        @map("duration_ms")
  errorMessage   String?     @map("error_message") @db.VarChar(1024)
  createdAt      DateTime    @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([target])
  @@index([status])
  @@index([createdAt])
  @@map("external_call_audit")
}

// ───────────────────────────────────────────────────────────
// 阶段 05 — 策略引擎与规则配置（功能清单 §1.7 规则部分 / 架构 §4.2 Policy）
// Policy 模块：权限判断、风险等级判断、确认拦截；平台侧显式规则存 Agent MySQL。
// 规则按租户隔离（实施规格 §1.4）；Tool 执行前必须调用 Policy（架构 §8）。
// rule_hit 为命中留痕（审计性质）：rule 删除后置空 ruleId 并保留快照字段，hit 历史不丢失。
// ───────────────────────────────────────────────────────────

/// 规则类型：与四类显式规则对应（执行计划 §3.1）
enum RuleType {
  high_risk        // 高风险动作识别规则
  confirm          // 确认拦截规则
  capability_limit // 能力级限制规则
  custom           // 通用显式规则
}

/// 规则命中后对请求的处置动作
enum RuleAction {
  allow          // 显式放行
  deny           // 拦截（不允许执行）
  need_confirm   // 需人工确认（中断执行，转 14-审批）
  mark_high_risk // 标记为高风险（供风险动作审计聚合）
}

enum RuleStatus {
  enabled
  disabled
}

/// 平台侧显式规则配置（按租户）
model Rule {
  id          String     @id @default(uuid()) @db.Char(36)
  tenantId    String     @map("tenant_id") @db.Char(36)
  name        String     @db.VarChar(128)
  type        RuleType
  // conditions：匹配条件 DSL（JSON），结构见模块 README；空对象表示租户内全量匹配
  conditions  Json
  action      RuleAction
  // priority：数值越小优先级越高，按 priority 升序评估
  priority    Int        @default(100)
  status      RuleStatus @default(enabled)
  description String?    @db.VarChar(512)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  hits   RuleHit[]

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([tenantId, status, priority])
  @@map("rule")
}

/// 规则命中记录（执行计划 §3.2）：请求命中的规则、时间、请求摘要、处理结果
model RuleHit {
  id             String     @id @default(uuid()) @db.Char(36)
  ruleId         String?    @map("rule_id") @db.Char(36)
  tenantId       String     @map("tenant_id") @db.Char(36)
  // 命中时的规则快照，确保规则删除后命中历史可读
  ruleName       String     @map("rule_name") @db.VarChar(128)
  ruleType       RuleType   @map("rule_type")
  ruleAction     RuleAction @map("rule_action")
  // result：本次请求最终处置（allow / deny / need_confirm）
  result         String     @db.VarChar(32)
  toolName       String?    @map("tool_name") @db.VarChar(128)
  capability     String?    @db.VarChar(32)
  requestSummary String?    @map("request_summary") @db.Text
  callerUserId   String?    @map("caller_user_id") @db.VarChar(256)
  sessionId      String?    @map("session_id") @db.Char(36)
  taskId         String?    @map("task_id") @db.Char(36)
  createdAt      DateTime   @default(now()) @map("created_at")

  rule   Rule?  @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([ruleId])
  @@index([tenantId])
  @@index([sessionId])
  @@index([taskId])
  @@index([createdAt])
  @@map("rule_hit")
}

// ───────────────────────────────────────────────────────────
// 阶段 06 — 连接器管理（功能清单 §1.6 / 架构 §4.4 Connector Management）
// 为 Query Tool（只读库）、Action Tool（HTTP）、Notification Tool 提供连接能力。
// 查询型仅经只读 DB，不经 HTTP 查数（架构 §4.4）；外部调用记入 04 external_call_audit。
// 连接器按租户隔离（实施规格 §1.4）：tenant_id 必须来自 tenant 表，非空。
// 凭证不落明文：敏感字段（口令/令牌/密钥）AES-256-GCM 加密后存于 config.secretCipher。
// ───────────────────────────────────────────────────────────

/// 连接器类型（功能清单 §1.6）
enum ConnectorType {
  db_readonly  // 只读数据库：查询型能力 / SQL Query Tool
  http         // HTTP API：操作型 Action Tool、流程型外部步骤（不用于查询型数据查询）
  notification // 消息通知接口：Notification Tool、流程型通知步骤
}

enum ConnectorStatus {
  enabled
  disabled
}

/// 连通性测试结果（最近一次）
enum ConnectorTestStatus {
  success
  failed
}

/// 外部连接器配置（按租户）
model Connector {
  id        String          @id @default(uuid()) @db.Char(36)
  tenantId  String          @map("tenant_id") @db.Char(36)
  name      String          @db.VarChar(128)
  type      ConnectorType
  // target：目标系统地址（http/notification 为 URL；db_readonly 为 host:port/库）
  target    String          @db.VarChar(512)
  // authType：认证方式 none/basic/bearer/api_key/custom（具体凭证见 config.secretCipher）
  authType  String          @default("none") @map("auth_type") @db.VarChar(32)
  timeoutMs Int             @default(5000) @map("timeout_ms")
  status    ConnectorStatus @default(enabled)
  // config：非敏感配置(properties)、可被引用的 Tool 范围(allowedToolScopes)、
  //         加密凭证(secretCipher)；结构见模块 README
  config    Json
  description String?       @db.VarChar(512)

  // 最近一次连通性测试快照（供列表 / 详情展示）
  lastTestStatus    ConnectorTestStatus? @map("last_test_status")
  lastTestLatencyMs Int?                 @map("last_test_latency_ms")
  lastTestMessage   String?              @map("last_test_message") @db.VarChar(512)
  lastTestedAt      DateTime?            @map("last_tested_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tools      Tool[]
  dbMetadata ConnectorDbMetadata?

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([tenantId, type, status])
  @@map("connector")
}

/// 只读库连接器元数据：表结构抽取 + ER 关系图（查询型能力 §4）
model ConnectorDbMetadata {
  connectorId         String    @id @map("connector_id") @db.Char(36)
  introspectedSchema  Json?     @map("introspected_schema")
  introspectedAt      DateTime? @map("introspected_at")
  erDiagramDraft      Json?     @map("er_diagram_draft")
  erDiagramPublished  Json?     @map("er_diagram_published")
  erPublishedVersion  Int?      @map("er_published_version")
  erPublishedAt       DateTime? @map("er_published_at")

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@map("connector_db_metadata")
}

// ───────────────────────────────────────────────────────────
// 阶段 07 — 工具注册与工具管理（功能清单 §1.5 / 架构 §4.3 Tool Registry）
// V1 所有 Tool 必须经注册中心，禁止绕过（架构 §4.3）。
// 四类 Tool：query / action / workflow / notification（执行计划 §3）。
// Tool 按租户隔离（实施规格 §1.4）：tenant_id 必须来自 tenant 表，非空。
// 关联连接器（按需）：connector_id → connector.id，连接器删除后置空（SetNull），
//   不阻断 Tool 历史（连接器恢复 / 重绑后可继续使用）。
// 执行前必须走 Policy（架构 §8）；调用记入 04 tool_call_audit。
// SQL 查询工具：query 型 + db_readonly 连接器，约束（表白名单/行数/时长）存于 config.sql。
// ───────────────────────────────────────────────────────────

/// Tool 类型（架构 §4.3 / 执行计划 §3）
enum ToolType {
  query        // 查询型：只读 SQL（SQL Query Tool）
  action       // 操作型：HTTP 写操作
  workflow     // 流程型：编排 Query/Action/Notification（编排执行见 12/13）
  notification // 通知型：消息通知接口
}

enum ToolStatus {
  enabled
  disabled
}

/// Tool 风险等级（执行计划 §3；Policy 评估输入 riskLevel）
enum ToolRiskLevel {
  low
  medium
  high
}

/// Tool 注册元数据（架构 §4.3 Tool Registry）
model Tool {
  id              String        @id @default(uuid()) @db.Char(36)
  tenantId        String        @map("tenant_id") @db.Char(36)
  name            String        @db.VarChar(128)
  description     String?       @db.VarChar(512)
  type            ToolType
  status          ToolStatus    @default(enabled)
  // inputSchema / outputSchema：JSON Schema（保存前校验合法性，非法拒绝，验收标准 1）
  inputSchema     Json          @map("input_schema")
  outputSchema    Json?         @map("output_schema")
  // permissionScope：Tool 权限范围 key（如 order:read）；Policy 能力级限制与连接器 allowedToolScopes 校验依据
  permissionScope String?       @map("permission_scope") @db.VarChar(128)
  riskLevel       ToolRiskLevel @default(low) @map("risk_level")
  // needConfirmation：高风险 / 显式需人工确认；执行前 Policy 命中即中断转审批（14）
  needConfirmation Boolean      @default(false) @map("need_confirmation")
  timeoutMs       Int           @default(10000) @map("timeout_ms")
  // idempotencyKey：幂等键模板（如基于入参字段），用于操作型重试去重；可空
  idempotencyKey  String?       @map("idempotency_key") @db.VarChar(128)
  // auditEventType：工具调用审计事件类型标识（写入 tool_call_audit 供分类）
  auditEventType  String?       @map("audit_event_type") @db.VarChar(128)
  // connectorId：关联连接器（query→db_readonly；action/workflow→http；notification→notification），可空
  connectorId     String?       @map("connector_id") @db.Char(36)
  // config：类型相关配置；query 含 SQL 工具配置(sql)，action/notification 含 HTTP 调用配置(http)，
  //         workflow 含步骤编排(workflow)；结构见模块 README
  config          Json
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  connector Connector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([riskLevel])
  @@index([connectorId])
  @@index([tenantId, type, status])
  @@map("tool")
}

// ───────────────────────────────────────────────────────────
// 阶段 08 — 会话与消息核心（功能清单 §1.2 / §4.1 / §4.2）
// Session：会话生命周期管理、上下文装配、历史查询。
// Message：用户/系统/工具/确认消息持久化与时间线。
// Session 与 Message 分模块实现（架构 §4.2）；按租户隔离（实施规格 §1.4）。
// ───────────────────────────────────────────────────────────

/// 会话状态
enum SessionStatus {
  active          // 进行中
  completed       // 已完成
  failed          // 执行失败
  cancelled       // 已取消
  pending_confirm // 等待人工确认（12 Agent Runtime / 14 审批）
}

/// 能力类型（与四类能力对应，架构 §4.3）
enum CapabilityType {
  qa         // 问答型
  query      // 查询型
  action     // 操作型
  workflow   // 流程型
}

/// 会话（架构 §4.2 Session 模块）
model Session {
  id             String         @id @default(uuid()) @db.Char(36)
  tenantId       String         @map("tenant_id") @db.Char(36)
  /// 管理端为 platform User.id；Copilot 为 JWT sub（copilot:appId:externalUserId）
  userId         String         @map("user_id") @db.VarChar(256)
  title          String?        @db.VarChar(256)
  status         SessionStatus  @default(active)
  capabilityType CapabilityType? @map("capability_type")
  summary        String?        @db.Text
  /// 是否触发任务（§1.2 列表列）
  hasTask        Boolean        @default(false) @map("has_task")
  /// 是否触发人工确认（§1.2 列表列）
  hasConfirmation Boolean       @default(false) @map("has_confirmation")
  /// 最近一条消息时间（冗余，供列表排序）
  lastMessageAt  DateTime?      @map("last_message_at")
  /// 嵌入主体快照：externalUserId、scopeList（创建会话时从 Copilot JWT 写入）
  principalContext Json?        @map("principal_context")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  messages Message[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([capabilityType])
  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@map("session")
}

/// 消息类型（架构 §4.2 Message 模块）
enum MessageType {
  user        // 用户消息
  system      // 系统消息（Agent 回复 / 中间输出）
  tool        // 工具消息（Tool 调用请求/响应）
  confirmation // 确认消息（人工确认节点）
}

/// 消息角色
enum MessageRole {
  user
  assistant
  system
  tool
}

/// 消息（架构 §4.2 Message 模块 — 独立于 Session 模块）
model Message {
  id        String      @id @default(uuid()) @db.Char(36)
  sessionId String      @map("session_id") @db.Char(36)
  type      MessageType
  role      MessageRole @default(user)
  /// 消息内容 JSON（结构因 type 而异，如 { text, toolName, params, result, ... }）
  content   Json
  /// 排序用序号（同会话内单调递增）
  seq       Int         @default(0)
  createdAt DateTime    @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, seq])
  @@index([type])
  @@index([createdAt])
  @@map("message")
}

// ───────────────────────────────────────────────────────────
// 阶段 09 — 任务中心与异步 Worker（功能清单 §1.3 / §4.3 Task / §4.11）
// Task：任务创建、状态推进、长任务跟踪、执行日志。
// TaskStep：流程型/异步型任务的步骤明细。
// TaskLog：任务级执行日志（工具调用、状态变更、异常堆栈、人工确认记录）。
// 按租户隔离（实施规格 §1.4）：tenant_id 必须来自 tenant 表。
// job-worker 通过 BullMQ 消费异步任务并更新状态（架构 §6.3）。
// ───────────────────────────────────────────────────────────

/// 任务状态（执行计划 §5.2 状态流转）
enum TaskStatus {
  pending         // 待执行（已入队 / 等待调度）
  running         // 执行中
  completed       // 已完成
  failed          // 执行失败
  cancelled       // 已取消
  timeout         // 执行超时
  pending_confirm // 等待人工确认（12 Agent Runtime / 14 审批）
}

/// 任务类型
enum TaskType {
  sync        // 同步任务（短任务，请求内完成）
  async       // 异步任务（入队由 worker 消费）
  scheduled   // 定时任务（超时检查、索引重建等）
}

/// 任务（架构 §4.2 Task 模块）
model Task {
  id             String         @id @default(uuid()) @db.Char(36)
  tenantId       String         @map("tenant_id") @db.Char(36)
  sessionId      String?        @map("session_id") @db.Char(36)
  userId         String?        @map("user_id") @db.VarChar(256)
  title          String?        @db.VarChar(256)
  type           TaskType       @default(async)
  status         TaskStatus     @default(pending)
  capabilityType CapabilityType? @map("capability_type")
  /// 当前执行节点描述
  currentNode    String?        @map("current_node") @db.VarChar(256)
  /// 入参 JSON
  input          Json?
  /// 出参 JSON
  output         Json?
  /// 重试次数
  retryCount     Int            @default(0) @map("retry_count")
  /// 最大重试次数
  maxRetries     Int            @default(3) @map("max_retries")
  /// 超时毫秒
  timeoutMs      Int            @default(300000) @map("timeout_ms")
  /// 失败原因
  failReason     String?        @map("fail_reason") @db.Text
  /// BullMQ Job ID（异步任务关联）
  jobId          String?        @map("job_id") @db.VarChar(128)
  /// 计划执行时间（定时任务）
  scheduledAt    DateTime?      @map("scheduled_at")
  startedAt      DateTime?      @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  steps  TaskStep[]
  logs   TaskLog[]

  @@index([tenantId])
  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([capabilityType])
  @@index([tenantId, status])
  @@index([tenantId, type, status])
  @@index([jobId])
  @@index([createdAt])
  @@map("task")
}

/// 步骤状态
enum TaskStepStatus {
  pending
  running
  completed
  failed
  skipped
}

/// 任务步骤（长任务跟踪 §5.3）
model TaskStep {
  id          String         @id @default(uuid()) @db.Char(36)
  taskId      String         @map("task_id") @db.Char(36)
  /// 步骤序号（同任务内单调递增）
  seq         Int            @default(0)
  name        String         @db.VarChar(256)
  description String?        @db.VarChar(512)
  status      TaskStepStatus @default(pending)
  /// 步骤入参 JSON
  input       Json?
  /// 步骤出参 JSON
  output      Json?
  /// 关联 Tool 名称
  toolName    String?        @map("tool_name") @db.VarChar(128)
  /// 失败原因
  failReason  String?        @map("fail_reason") @db.Text
  /// 耗时（毫秒）
  durationMs  Int?           @map("duration_ms")
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, seq])
  @@index([status])
  @@map("task_step")
}

// ───────────────────────────────────────────────────────────
// 阶段 10 — 能力路由（功能清单 §1.4 / 架构 Capability Routing）
// 将用户请求路由到四类能力（qa/query/action/workflow），输出统一能力结果结构。
// 能力目录：维护平台能力清单（描述、适用系统、依赖工具、权限要求）。
// 路由规则：配置能力与 Tool/规则的关联、每类能力可调用范围。
// 路由测试：输入测试语句命中能力类型/理由/候选能力/是否需确认。
// 按租户隔离（实施规格 §1.4）：tenant_id 必须来自 tenant 表。
// ───────────────────────────────────────────────────────────

/// 能力状态
enum CapabilityStatus {
  enabled
  disabled
}

/// 能力目录（平台能力清单 §1.4）
model Capability {
  id              String           @id @default(uuid()) @db.Char(36)
  tenantId        String           @map("tenant_id") @db.Char(36)
  /// 能力类型：qa/query/action/workflow
  type            CapabilityType
  /// 能力名称（租户内唯一）
  name            String           @db.VarChar(128)
  description     String?          @db.VarChar(512)
  /// 适用系统/业务场景
  applicableSystem String?         @map("applicable_system") @db.VarChar(256)
  /// 依赖的工具 ID 列表（JSON string[]）
  dependentTools  Json?            @map("dependent_tools")
  /// 权限要求（permissionScope 列表，JSON string[]）
  permissionRequirements Json?     @map("permission_requirements")
  /// 路由优先级（数值越小越优先）
  priority        Int              @default(100)
  status          CapabilityStatus @default(enabled)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  routingRules RoutingRule[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([tenantId, type, status])
  @@map("capability")
}

/// 路由规则状态
enum RoutingRuleStatus {
  enabled
  disabled
}

/// 路由规则（能力与 Tool / 策略规则的关联配置）
model RoutingRule {
  id           String            @id @default(uuid()) @db.Char(36)
  tenantId     String            @map("tenant_id") @db.Char(36)
  capabilityId String            @map("capability_id") @db.Char(36)
  /// 规则名称
  name         String            @db.VarChar(128)
  description  String?           @db.VarChar(512)
  /// 匹配条件 DSL（JSON）：关键词、意图模式等
  conditions   Json
  /// 关联的 Tool ID 列表（命中时可调用的工具范围，JSON string[]）
  toolIds      Json?             @map("tool_ids")
  /// 路由优先级（同能力内数值越小越优先）
  priority     Int               @default(100)
  /// 是否需人工确认（独立于 Policy 的路由级确认）
  needConfirmation Boolean       @default(false) @map("need_confirmation")
  status       RoutingRuleStatus @default(enabled)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([capabilityId])
  @@index([tenantId, status, priority])
  @@map("routing_rule")
}

/// 任务日志级别
enum TaskLogLevel {
  info
  warn
  error
}

/// 任务日志类型
enum TaskLogType {
  state_change   // 状态变更
  tool_call      // 工具调用
  error          // 异常
  confirmation   // 人工确认记录
  notification   // 异步通知发送
  retry          // 重试记录
  custom         // 自定义
}

/// 任务执行日志（§5.4 执行日志）
model TaskLog {
  id        String       @id @default(uuid()) @db.Char(36)
  taskId    String       @map("task_id") @db.Char(36)
  stepId    String?      @map("step_id") @db.Char(36)
  type      TaskLogType
  level     TaskLogLevel @default(info)
  message   String       @db.Text
  /// 日志附加数据（工具调用入参/出参、异常堆栈、确认详情等）
  detail    Json?
  createdAt DateTime     @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, type])
  @@index([stepId])
  @@index([level])
  @@index([createdAt])
  @@map("task_log")
}

// ───────────────────────────────────────────────────────────
// 阶段 11 — 技能书管理（功能清单 §1.5A / 架构 Skill Management）
// 技能书是四类能力之上的业务封装层，不构成第五类能力。
// Agent Runtime 在能力类型确定后消费技能书选择结果。
// 按租户隔离（实施规格 §1.4）：tenant_id 必须来自 tenant 表。
// ───────────────────────────────────────────────────────────

/// 技能书状态
enum SkillStatus {
  draft    // 草稿
  enabled  // 启用
  disabled // 停用
}

/// 技能书风险等级
enum SkillRiskLevel {
  low
  medium
  high
}

/// 技能书入口模式
enum SkillEntryMode {
  tool      // 直接绑定主 Tool
  workflow  // 绑定 Workflow Tool
}

/// 技能书（技能书设计 §4.1 / 功能清单 §1.5A）
model Skill {
  id               String           @id @default(uuid()) @db.Char(36)
  tenantId         String           @map("tenant_id") @db.Char(36)
  code             String           @db.VarChar(64)
  name             String           @db.VarChar(128)
  description      String?          @db.VarChar(512)
  /// 技能类别（自定义分类标签）
  category         String?          @db.VarChar(64)
  /// 归属能力类型
  capabilityType   CapabilityType   @map("capability_type")
  status           SkillStatus      @default(draft)
  version          Int              @default(1)
  riskLevel        SkillRiskLevel   @default(low) @map("risk_level")
  needConfirmation Boolean          @default(false) @map("need_confirmation")
  /// 权限范围（与 Tool permissionScope 一致语义）
  permissionScope  String?          @map("permission_scope") @db.VarChar(128)
  entryMode        SkillEntryMode   @map("entry_mode")
  /// 主 Tool ID（entryMode=tool 时必填）
  entryToolId      String?          @map("entry_tool_id") @db.Char(36)
  /// Workflow Tool ID（entryMode=workflow 时必填）
  workflowToolId   String?          @map("workflow_tool_id") @db.Char(36)
  /// 输入参数 schema（JSON Schema）
  inputSchema      Json?            @map("input_schema")
  /// 输出结果 schema（JSON Schema）
  outputSchema     Json?            @map("output_schema")
  /// 前置条件（JSON）
  preconditions    Json?
  /// 结果模板
  resultTemplate   String?          @map("result_template") @db.Text
  /// 缺参追问策略（JSON）
  missingParamStrategy Json?        @map("missing_param_strategy")
  /// 失败提示
  failureHint      String?          @map("failure_hint") @db.VarChar(512)
  remark           String?          @db.VarChar(512)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  triggers      SkillTrigger[]
  bindings      SkillBinding[]
  executionLogs SkillExecutionLog[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([capabilityType])
  @@index([status])
  @@index([riskLevel])
  @@index([tenantId, capabilityType, status])
  @@map("skill")
}

/// 技能书触发示例（技能书设计 §4.2）
model SkillTrigger {
  id          String @id @default(uuid()) @db.Char(36)
  skillId     String @map("skill_id") @db.Char(36)
  /// 触发文本示例
  triggerText String @map("trigger_text") @db.VarChar(512)
  /// 触发类型（keyword / intent / regex）
  triggerType String @default("keyword") @map("trigger_type") @db.VarChar(32)
  /// 优先级（数值越小越优先）
  priority    Int    @default(100)

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@map("skill_trigger")
}

/// 技能书绑定关系（技能书设计 §4.3）
model SkillBinding {
  id          String  @id @default(uuid()) @db.Char(36)
  skillId     String  @map("skill_id") @db.Char(36)
  /// 绑定类型（tool / workflow / connector）
  bindingType String  @map("binding_type") @db.VarChar(32)
  /// 目标 ID（Tool ID / Workflow Tool ID / Connector ID）
  targetId    String  @map("target_id") @db.Char(36)
  /// 执行顺序
  orderNo     Int     @default(0) @map("order_no")
  /// 绑定配置（JSON）
  config      Json?

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@map("skill_binding")
}

/// 技能书执行记录状态
enum SkillExecStatus {
  success
  failed
  running
  timeout
}

/// 技能书执行记录（技能书设计 §4.4 / 功能清单 §1.5A 调用记录）
model SkillExecutionLog {
  id             String          @id @default(uuid()) @db.Char(36)
  skillId        String          @map("skill_id") @db.Char(36)
  sessionId      String?         @map("session_id") @db.Char(36)
  taskId         String?         @map("task_id") @db.Char(36)
  tenantId       String          @map("tenant_id") @db.Char(36)
  userId         String?         @map("user_id") @db.VarChar(256)
  status         SkillExecStatus @default(running)
  /// 输入快照（JSON）
  inputSnapshot  Json?           @map("input_snapshot")
  /// 输出快照（JSON）
  outputSnapshot Json?           @map("output_snapshot")
  /// 失败原因
  errorSummary   String?         @map("error_summary") @db.VarChar(1024)
  startedAt      DateTime        @default(now()) @map("started_at")
  finishedAt     DateTime?       @map("finished_at")

  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Restrict)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([skillId])
  @@index([tenantId])
  @@index([sessionId])
  @@index([taskId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@map("skill_execution_log")
}

// ───────────────────────────────────────────────────────────
// 阶段 11A — 知识库代理与知识库管理（功能清单 §1.7 / 架构 Knowledge）
// 知识库全生命周期：创建/数据源/文档上传/分块/向量化/检索。
// 按租户隔离（实施规格 §1.4）：tenant_id 必须来自 tenant 表。
// V1 embedding 以 JSON 存储于 MySQL；生产建议迁移专用向量数据库。
// ───────────────────────────────────────────────────────────

/// 知识库状态
enum KnowledgeBaseStatus {
  active
  disabled
  deleted
}

/// 知识库主表
model KnowledgeBase {
  id              String              @id @default(uuid()) @db.Char(36)
  tenantId        String              @map("tenant_id") @db.Char(36)
  name            String              @db.VarChar(128)
  description     String?             @db.VarChar(512)
  /// wiki 子路径前缀（租户隔离）；空则默认 tenants/{tenantId}/
  wikiPrefix        String?             @map("wiki_prefix") @db.VarChar(256)
  embeddingModel  String              @default("text-embedding-3-small") @map("embedding_model") @db.VarChar(128)
  similarityMetric String             @default("cosine") @map("similarity_metric") @db.VarChar(32)
  chunkStrategy   String              @default("fixed_size") @map("chunk_strategy") @db.VarChar(32)
  chunkSize       Int                 @default(500) @map("chunk_size")
  chunkOverlap    Int                 @default(50) @map("chunk_overlap")
  status          KnowledgeBaseStatus @default(active)
  documentCount   Int                 @default(0) @map("document_count")
  chunkCount      Int                 @default(0) @map("chunk_count")
  createdBy       String?             @map("created_by") @db.Char(36)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  dataSources     KbDataSource[]
  documents       KbDocument[]
  chunks          KbChunk[]
  embeddingTasks  KbEmbeddingTask[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([createdAt])
  @@map("knowledge_base")
}

/// 数据源类型
enum KbDataSourceType {
  file
  url
  api
  connector
}

/// 数据源状态
enum KbDataSourceStatus {
  active
  disabled
  error
}

/// 知识库数据源
model KbDataSource {
  id              String             @id @default(uuid()) @db.Char(36)
  knowledgeBaseId String             @map("knowledge_base_id") @db.Char(36)
  tenantId        String             @map("tenant_id") @db.Char(36)
  name            String             @db.VarChar(128)
  type            KbDataSourceType   @default(file)
  config          Json?
  syncCron        String?            @map("sync_cron") @db.VarChar(64)
  lastSyncAt      DateTime?          @map("last_sync_at")
  status          KbDataSourceStatus @default(active)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  documents     KbDocument[]

  @@index([knowledgeBaseId])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@map("kb_data_source")
}

/// 文档状态
enum KbDocumentStatus {
  pending
  chunking
  embedding
  ready
  error
}

/// 知识库文档
model KbDocument {
  id              String           @id @default(uuid()) @db.Char(36)
  dataSourceId    String?          @map("data_source_id") @db.Char(36)
  knowledgeBaseId String           @map("knowledge_base_id") @db.Char(36)
  tenantId        String           @map("tenant_id") @db.Char(36)
  title           String           @db.VarChar(256)
  fileKey         String?          @map("file_key") @db.VarChar(512)
  fileSize        Int?             @map("file_size")
  mimeType        String?          @map("mime_type") @db.VarChar(128)
  contentHash     String?          @map("content_hash") @db.VarChar(64)
  charCount       Int              @default(0) @map("char_count")
  chunkCount      Int              @default(0) @map("chunk_count")
  status          KbDocumentStatus @default(pending)
  errorMsg        String?          @map("error_msg") @db.VarChar(1024)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  knowledgeBase KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  dataSource    KbDataSource?    @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  chunks        KbChunk[]
  embeddingTasks KbEmbeddingTask[]

  @@index([knowledgeBaseId])
  @@index([dataSourceId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("kb_document")
}

/// 知识库文档分块
model KbChunk {
  id              String        @id @default(uuid()) @db.Char(36)
  documentId      String        @map("document_id") @db.Char(36)
  knowledgeBaseId String        @map("knowledge_base_id") @db.Char(36)
  tenantId        String        @map("tenant_id") @db.Char(36)
  content         String        @db.Text
  tokenCount      Int           @default(0) @map("token_count")
  chunkIndex      Int           @default(0) @map("chunk_index")
  metadata        Json?
  /// V1: embedding 存 JSON 数组；生产建议迁移至专用向量数据库
  embedding       Json?
  createdAt       DateTime      @default(now()) @map("created_at")

  document      KbDocument    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([documentId])
  @@index([knowledgeBaseId])
  @@index([tenantId])
  @@index([documentId, chunkIndex])
  @@map("kb_chunk")
}

/// 向量化任务状态
enum KbEmbeddingTaskStatus {
  queued
  running
  done
  failed
}

/// 向量化任务
model KbEmbeddingTask {
  id              String                @id @default(uuid()) @db.Char(36)
  knowledgeBaseId String                @map("knowledge_base_id") @db.Char(36)
  tenantId        String                @map("tenant_id") @db.Char(36)
  documentId      String?               @map("document_id") @db.Char(36)
  status          KbEmbeddingTaskStatus @default(queued)
  totalChunks     Int                   @default(0) @map("total_chunks")
  processedChunks Int                   @default(0) @map("processed_chunks")
  errorMsg        String?               @map("error_msg") @db.VarChar(1024)
  startedAt       DateTime?             @map("started_at")
  finishedAt      DateTime?             @map("finished_at")
  createdAt       DateTime              @default(now()) @map("created_at")

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  document      KbDocument?   @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([knowledgeBaseId])
  @@index([tenantId])
  @@index([documentId])
  @@index([status])
  @@index([createdAt])
  @@map("kb_embedding_task")
}

/// wiki 层文件异步处理任务（编译 raw→wiki、wiki 嵌入索引）
enum KbLayerProcessingStatus {
  queued
  running
  done
  failed
}

model KbLayerProcessingJob {
  id             String                  @id @default(uuid()) @db.Char(36)
  tenantId       String                  @map("tenant_id") @db.Char(36)
  layer          String                  @db.VarChar(32)
  inputPath      String                  @map("input_path") @db.VarChar(512)
  outputPath     String?                 @map("output_path") @db.VarChar(512)
  operation      String                  @default("compile_and_embed") @db.VarChar(32)
  status         KbLayerProcessingStatus @default(queued)
  idempotencyKey String                  @unique @map("idempotency_key") @db.VarChar(256)
  bullJobId      String?                 @map("bull_job_id") @db.VarChar(64)
  errorMsg       String?                 @map("error_msg") @db.VarChar(1024)
  result         Json?
  startedAt      DateTime?               @map("started_at")
  finishedAt     DateTime?               @map("finished_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("kb_layer_processing_job")
}

// ───────────────────────────────────────────────────────────
// 阶段 14 — 审批中心（功能清单 §1.8 / 架构 §4.5 人工确认）
// 高风险动作人工确认全生命周期：待确认→已确认/已驳回/已超时。
// 与 Agent Runtime 联动：确认中断时创建记录，确认后继续/驳回后失败。
// 按租户隔离（实施规格 §1.4）：tenant_id 必须来自 tenant 表。
// ───────────────────────────────────────────────────────────

/// 审批状态
enum ApprovalStatus {
  pending   // 待确认
  approved  // 已确认执行
  rejected  // 已驳回
  timeout   // 已超时
}

/// 风险等级（复用 ToolRiskLevel 语义）
enum ApprovalRiskLevel {
  low
  medium
  high
}

/// 审批记录（功能清单 §1.8 / 执行计划 §5）
model Approval {
  id              String             @id @default(uuid()) @db.Char(36)
  tenantId        String             @map("tenant_id") @db.Char(36)
  sessionId       String?            @map("session_id") @db.Char(36)
  taskId          String?            @map("task_id") @db.Char(36)
  messageId       String?            @map("message_id") @db.Char(36)
  /// 发起人：管理端 user.id；Copilot 为 JWT sub
  initiatorId     String?            @map("initiator_id") @db.VarChar(256)
  /// 发起人名称快照
  initiatorName   String?            @map("initiator_name") @db.VarChar(128)
  /// 动作类型 / Tool 名称
  actionType      String             @map("action_type") @db.VarChar(128)
  /// 动作摘要（操作背景、原始请求概要）
  actionSummary   String?            @map("action_summary") @db.Text
  riskLevel       ApprovalRiskLevel  @default(high) @map("risk_level")
  /// 影响范围描述
  impactScope     String?            @map("impact_scope") @db.VarChar(512)
  /// 待执行 Tool ID 列表（JSON 数组）
  toolIds         Json?              @map("tool_ids")
  /// 原始请求上下文快照
  requestContext  Json?              @map("request_context")
  status          ApprovalStatus     @default(pending)
  /// 审批人 user.id
  reviewerId      String?            @map("reviewer_id") @db.Char(36)
  /// 审批人名称快照
  reviewerName    String?            @map("reviewer_name") @db.VarChar(128)
  /// 审批意见
  opinion         String?            @db.Text
  reviewedAt      DateTime?          @map("reviewed_at")
  /// 超时截止时间
  expiredAt       DateTime?          @map("expired_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([sessionId])
  @@index([taskId])
  @@index([status])
  @@index([initiatorId])
  @@index([reviewerId])
  @@index([actionType])
  @@index([riskLevel])
  @@index([tenantId, status])
  @@index([createdAt])
  @@index([reviewedAt])
  @@map("approval")
}

// ───────────────────────────────────────────────────────────
// 阶段 18 — 系统设置（功能清单 §1.13）
// 平台级 KV 配置表：基础信息、模型与响应、通知渠道与模板。
// Runtime、job-worker 读取配置时走短 TTL 缓存（Redis）。
// ───────────────────────────────────────────────────────────

/// 系统配置（KV 表），configKey 全局唯一
model SystemConfig {
  id         String   @id @default(uuid()) @db.Char(36)
  /// 配置分组：basic / model / notification
  configGroup String  @map("config_group") @db.VarChar(64)
  /// 配置键，全局唯一
  configKey  String   @unique @map("config_key") @db.VarChar(128)
  /// 配置值（JSON 字符串或纯文本）
  configValue String  @map("config_value") @db.Text
  /// 配置说明
  description String? @db.VarChar(512)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([configGroup])
  @@map("system_config")
}

/// 通知模板类型
enum NotificationTemplateType {
  approval      // 审批通知
  task_complete // 任务完成通知
  exception     // 异常通知
}

/// 通知模板
model NotificationTemplate {
  id           String                   @id @default(uuid()) @db.Char(36)
  type         NotificationTemplateType
  name         String                   @db.VarChar(128)
  /// 模板主题
  subject      String?                  @db.VarChar(256)
  /// 模板内容（支持变量占位符 {{var}}）
  body         String                   @db.Text
  /// 是否启用
  enabled      Boolean                  @default(true)
  /// 关联通知连接器 ID（connector 表中 type=notification 的连接器）
  connectorId  String?                  @map("connector_id") @db.Char(36)
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  @@unique([type, name])
  @@index([type])
  @@index([enabled])
  @@map("notification_template")
}

// ───────────────────────────────────────────────────────────
// 阶段 15 — OpenAPI 对外接口与管理（功能清单 §3 / §1.12）
// 对外提供应用鉴权、会话、消息、SSE、任务、人工确认 REST/SSE API。
// 管理后台实现应用接入、接口文档、调用日志。
// 应用级 API Key / Client Secret → JWT 鉴权；限流状态存 Redis。
// 按租户隔离（实施规格 §1.4）：允许访问的租户由应用配置决定。
// ───────────────────────────────────────────────────────────

/// 接入应用状态
enum OpenApiAppStatus {
  enabled
  disabled
}

/// OpenAPI 接入应用（§1.12 应用接入 / 执行计划 §3.1）
model OpenApiApp {
  id              String           @id @default(uuid()) @db.Char(36)
  /// 应用名称（全局唯一）
  name            String           @unique @db.VarChar(128)
  description     String?          @db.VarChar(512)
  /// 应用标识（Client ID，用于鉴权请求）
  clientId        String           @unique @map("client_id") @db.VarChar(64)
  /// 加密后的 Client Secret（AES-256-GCM）
  clientSecretHash String          @map("client_secret_hash") @db.VarChar(255)
  status          OpenApiAppStatus @default(enabled)
  /// 允许访问的租户 ID 列表（JSON string[]）
  allowedTenantIds Json            @map("allowed_tenant_ids")
  /// 允许访问的能力范围（JSON string[]，如 ["qa","query","action","workflow"]）
  allowedCapabilities Json         @map("allowed_capabilities")
  /// 限流配置：{ rateLimit: number, windowMs: number }
  rateLimitConfig Json?            @map("rate_limit_config")
  /// 最近一次调用时间
  lastCalledAt    DateTime?        @map("last_called_at")
  /// 创建人 user.id
  createdBy       String?          @map("created_by") @db.Char(36)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  callLogs      OpenApiCallLog[]
  copilotConfig CopilotConfig?

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("openapi_app")
}

// ───────────────────────────────────────────────────────────
// 阶段 19 — 嵌入式 Copilot（功能清单 §2 / 架构 §4.1 接入层）
// Copilot 嵌入配置：每个 OpenAPI 应用可关联一份 Copilot 配置。
// ───────────────────────────────────────────────────────────

enum CopilotConfigStatus {
  enabled
  disabled
}

model CopilotConfig {
  id                 String              @id @default(uuid()) @db.Char(36)
  tenantId           String              @map("tenant_id") @db.Char(36)
  appId              String              @unique @map("app_id") @db.Char(36)
  name               String              @db.VarChar(128)
  status             CopilotConfigStatus @default(enabled)
  domainWhitelist    Json?               @map("domain_whitelist")
  theme              Json?
  features           Json?
  welcomeMessage     String?             @map("welcome_message") @db.Text
  placeholder        String?             @db.VarChar(256)
  maxHistoryMessages Int                 @default(50) @map("max_history_messages")
  tokenTtlSeconds    Int                 @default(3600) @map("token_ttl_seconds")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  app    OpenApiApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("copilot_config")
}

/// 调用日志状态
enum OpenApiCallStatus {
  success
  failed
  rate_limited
}

/// OpenAPI 调用日志（§1.12 调用日志 / 执行计划 §3.3）
model OpenApiCallLog {
  id            String            @id @default(uuid()) @db.Char(36)
  appId         String            @map("app_id") @db.Char(36)
  tenantId      String?           @map("tenant_id") @db.Char(36)
  /// 请求方法
  method        String            @db.VarChar(10)
  /// 请求路径
  path          String            @db.VarChar(256)
  /// HTTP 状态码
  statusCode    Int               @map("status_code")
  status        OpenApiCallStatus @default(success)
  /// 请求 IP
  ip            String?           @db.VarChar(64)
  /// 耗时毫秒
  durationMs    Int?              @map("duration_ms")
  /// 错误信息
  errorMessage  String?           @map("error_message") @db.VarChar(1024)
  /// 请求摘要
  requestSummary String?          @map("request_summary") @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")

  app    OpenApiApp @relation(fields: [appId], references: [id], onDelete: Restrict)
  tenant Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([appId])
  @@index([tenantId])
  @@index([status])
  @@index([path])
  @@index([createdAt])
  @@index([appId, status])
  @@index([appId, createdAt])
  @@map("openapi_call_log")
}

// ───────────────────────────────────────────────────────────
// 阶段 21 — Prompt 管理（方案 §5.3）
// LLM 提示词 SSOT：模板、版本、业务绑定。
// ───────────────────────────────────────────────────────────

enum PromptCategory {
  qa
  query
  sql_conversion
  connector
  routing
  runtime
  common
}

enum PromptRole {
  system
  user
  fragment
}

enum PromptScope {
  global
  tenant
}

enum PromptTemplateStatus {
  active
  archived
}

enum PromptVersionState {
  draft
  published
  deprecated
}

enum PromptBindType {
  capability
  skill
  tool
  connector
  default
}

model PromptTemplate {
  id             String               @id @default(uuid()) @db.Char(36)
  promptKey      String               @map("prompt_key") @db.VarChar(128)
  name           String               @db.VarChar(128)
  description    String?              @db.VarChar(512)
  category       PromptCategory
  role           PromptRole
  scope          PromptScope          @default(global)
  tenantId       String?              @map("tenant_id") @db.Char(36)
  variableSchema Json?                @map("variable_schema")
  status         PromptTemplateStatus @default(active)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  tenant   Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  versions PromptVersion[]

  @@unique([promptKey, scope, tenantId])
  @@index([category])
  @@index([status])
  @@index([tenantId])
  @@map("prompt_template")
}

model PromptVersion {
  id          String             @id @default(uuid()) @db.Char(36)
  templateId  String             @map("template_id") @db.Char(36)
  version     Int
  content     String             @db.MediumText
  contentHash String             @map("content_hash") @db.Char(64)
  changelog   String?            @db.VarChar(512)
  state       PromptVersionState @default(draft)
  publishedAt DateTime?          @map("published_at")
  publishedBy String?            @map("published_by") @db.Char(36)
  createdAt   DateTime           @default(now()) @map("created_at")

  template PromptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId, state])
  @@map("prompt_version")
}

model PromptBinding {
  id        String         @id @default(uuid()) @db.Char(36)
  tenantId  String?        @map("tenant_id") @db.Char(36)
  bindType  PromptBindType @map("bind_type")
  bindId    String?        @map("bind_id") @db.Char(36)
  promptKey String         @map("prompt_key") @db.VarChar(128)
  priority  Int            @default(0)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([bindType, bindId, tenantId])
  @@index([promptKey])
  @@map("prompt_binding")
}
